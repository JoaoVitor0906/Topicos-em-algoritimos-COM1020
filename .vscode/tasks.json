{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: cl.exe construir projeto completo",
            "command": "cmd.exe",
            "args": [
                "/c",
                "cd /d \"${workspaceFolder}\\CodeBlocks - teste\\teste2\" && cl.exe /Zi /EHsc /nologo /I\"include\" /Fe\"teste2.exe\" main.cpp \"bibliotecas\\algoritmos.cpp\" \"bibliotecas\\gerador.cpp\" \"bibliotecas\\benchmark.cpp\""
            ],
            "options": {
                "cwd": "${workspaceFolder}\\CodeBlocks - teste\\teste2"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Compila todos os arquivos-fonte do projeto com estrutura de biblioteca."
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "C:\\Strawberry\\c\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "\"${workspaceFolder}\\CodeBlocks - teste\\teste2\\main.cpp\"",
                "\"${workspaceFolder}\\CodeBlocks - teste\\teste2\\bibliotecas\\algoritmos.cpp\"",
                "\"${workspaceFolder}\\CodeBlocks - teste\\teste2\\bibliotecas\\gerador.cpp\"",
                "\"${workspaceFolder}\\CodeBlocks - teste\\teste2\\bibliotecas\\benchmark.cpp\"",
                "-I\"${workspaceFolder}\\CodeBlocks - teste\\teste2\\include\"",
                "-static-libgcc",
                "-static-libstdc++",
                "-o",
                "\"${workspaceFolder}\\CodeBlocks - teste\\teste2\\teste2.exe\""
            ],
            "options": {
                "cwd": "${workspaceFolder}\\CodeBlocks - teste\\teste2"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compila e linka o projeto C++ completo com MinGW g++."
        }
    ],
    "version": "2.0.0"
}